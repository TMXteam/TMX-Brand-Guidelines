{
  "$name": "predixa brand tokens",
  "$note": "Verbatim from the partner kit. Values are CSS colours/gradients. dark is canonical; light is a designed daylight twin, not an inversion.",
  "font": {
    "sans": "\"Inter\",system-ui,-apple-system,\"Helvetica Neue\",sans-serif",
    "serif": "\"Fraunces\",Georgia,serif",
    "mono": "\"JetBrains Mono\",ui-monospace,SFMono-Regular,Menlo,monospace"
  },
  "radius": {
    "r-card": "22px",
    "r-pill": "9999px"
  },
  "color": {
    "dark": {
      "bg": "#0A0A0C",
      "ink": "#F2F2F2",
      "accent": "#FFB627",
      "accent-deep": "#D79F1E",
      "accent-mid": "#E08F0F",
      "accent-high": "#FFD89A",
      "foil": "linear-gradient(135deg,#FFD89A,#FFB627,#E08F0F)",
      "select": "#7DF9D5",
      "yes": "#7DE0B0",
      "no": "#E07A7A"
    },
    "light": {
      "bg": "#F6F2E8",
      "ink": "#16140F",
      "accent": "#0E7A40",
      "accent-deep": "#0A5630",
      "accent-mid": "#0C6E3A",
      "accent-high": "#2AA862",
      "foil": "linear-gradient(135deg,#1FA85C,#0B6E39)",
      "select": "#9CE1C8",
      "yes": "#1F9E57",
      "no": "#C0392B"
    }
  }
}
