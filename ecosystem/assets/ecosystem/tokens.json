{
  "$name": "ecosystem brand tokens",
  "$note": "Verbatim from the partner kit. Values are CSS colours/gradients. dark is canonical; light is a designed daylight twin, not an inversion.",
  "font": {
    "sans": "\"Inter\",system-ui,-apple-system,\"Helvetica Neue\",sans-serif",
    "serif": "\"Fraunces\",Georgia,serif",
    "mono": "\"JetBrains Mono\",ui-monospace,SFMono-Regular,Menlo,monospace"
  },
  "radius": {
    "r-card": "22px",
    "r-pill": "9999px"
  },
  "color": {
    "dark": {
      "bg": "#0A0A0C",
      "ink": "#F2F2F2",
      "accent": "#D67341",
      "accent-deep": "#8B3F1F",
      "accent-mid": "#AF592D",
      "accent-high": "#FEE5A2",
      "foil": "linear-gradient(135deg,#FEE5A2,#D67341,#AF592D)",
      "select": "#7DF9D5",
      "yes": "#7DE0B0",
      "no": "#E07A7A"
    },
    "light": {
      "bg": "#F6F2E8",
      "ink": "#16140F",
      "accent": "#A54D1F",
      "accent-deep": "#A44A24",
      "accent-mid": "#B6562F",
      "accent-high": "#EBB371",
      "foil": "linear-gradient(135deg,#EBB371,#B6562F,#A44A24)",
      "select": "#9CE1C8",
      "yes": "#1F9E57",
      "no": "#C0392B"
    }
  }
}
